# Copy this file to .env and fill in your credentials.
# Supabase and Finnhub are required for production use.

# ── Supabase (required) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Finnhub real-time market data (required) ─────────────────────────────────
# Free tier at https://finnhub.io — grants 60 API calls/min, WebSocket trades.
# Required for all performance data, charts, and real-time prices.
VITE_FINNHUB_API_KEY=

# ── Resend Email (recommended) ───────────────────────────────────────────────
# Resend (https://resend.com) handles all outbound email. Two setup steps:
#
# STEP 1 — Auth emails (signup confirmation, password reset):
#   Configure Resend as custom SMTP in Supabase Dashboard:
#   Project Settings → Auth → SMTP Settings → Enable Custom SMTP
#     Host:     smtp.resend.com
#     Port:     465
#     User:     resend
#     Password: <your Resend API key>
#     Sender:   noreply@yourdomain.com  (must match a verified domain in Resend)
#
#   This bypasses Supabase's default email rate limit (~2/hour) entirely.
#
# STEP 2 — Custom emails (invites, notifications, etc.):
#   The app uses a Supabase Edge Function (supabase/functions/send-email)
#   that calls Resend's API directly. To deploy:
#
#   1. Set your Resend API key as a Supabase secret:
#      supabase secrets set RESEND_API_KEY=re_xxxxx
#
#   2. Set the sender address (must match a verified Resend domain):
#      supabase secrets set RESEND_FROM="AJA Wealth Management <noreply@yourdomain.com>"
#
#   3. Deploy the Edge Function:
#      supabase functions deploy send-email
#
#   If the Edge Function is not deployed, invite emails fall back to opening
#   the user's email client with a pre-filled mailto: link.
#
# Quick-start with Resend's test domain (no domain verification needed):
#   Use RESEND_FROM="AJA Wealth Management <onboarding@resend.dev>"
#   Note: test domain can only send to the email on your Resend account.

# ── Schwab Brokerage API (optional) ───────────────────────────────────────────
# Links Schwab accounts to show actual vs target holdings in portfolios.
# Register an app at https://developer.schwab.com to get credentials.
#
# Client-side (used to construct OAuth URL — safe to expose):
VITE_SCHWAB_CLIENT_ID=
#
# Server-side only (used in Vercel serverless functions — NEVER prefix with VITE_):
# Set these in Vercel Environment Variables, NOT in .env for production.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://yourapp.vercel.app/api/schwab-auth
#
# Supabase service-role key (server-side only — needed for token storage):
SUPABASE_SERVICE_ROLE_KEY=
